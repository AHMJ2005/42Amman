#include <unistd.h>

void fizzbuzz(void)
{
	int i = 1;
	while (i <= 100){
	if (i % 3 == 0 && i % 5 == 5)
		write(1 , "fizzbuzz\n" , 9);
	else if (i % 5 == 0)
		write(1 , "buzz\n" , 5);
	else if (i % 3 == 0)
		write (1 , "fizz\n" , 5);
	else
	{
		char n = i + '0';
		write (1 , &n , 1);
	}
	i++;
}
}
int main()
{
	fizzbuzz();
}
